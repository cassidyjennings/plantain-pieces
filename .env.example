# OAuth credentials for the Supabase CLI. The Supabase CLI substitutes env(...) references
# in supabase/config.toml from a `.env` file at the project root.
#
# Setup: copy this file to `.env` (which is gitignored) and fill in a real value from your
# Google Cloud account, then run `npm run db:start` (or restart the stack) so it takes
# effect. Until then, "Continue with Google" redirects to the provider and fails with an
# invalid-client error. Full step-by-step: docs/OAUTH_SETUP.md.
#
# (Apple Sign In is intentionally not offered — it requires a paid Apple Developer account.)
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=replace-with-google-client-id
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=replace-with-google-secret
