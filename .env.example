# OAuth credentials for the Supabase CLI. The Supabase CLI substitutes env(...) references
# in supabase/config.toml from a `.env` file at the project root.
#
# Setup: copy this file to `.env` (which is gitignored) and fill in real values from your
# Google Cloud and Apple Developer accounts, then run `npm run db:start` (or restart the
# stack) so the values take effect. Until then, "Continue with Google/Apple" redirects to
# the provider and fails with an invalid-client error. Full step-by-step: docs/OAUTH_SETUP.md.
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=replace-with-google-client-id
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=replace-with-google-secret
SUPABASE_AUTH_EXTERNAL_APPLE_CLIENT_ID=replace-with-apple-services-id
SUPABASE_AUTH_EXTERNAL_APPLE_SECRET=replace-with-apple-secret
