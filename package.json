{
  "name": "plantain-pieces",
  "private": true,
  "version": "0.0.0",
  "description": "Plantain Pieces — online Bananagrams-style multiplayer word game",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build:shared": "npm run build --workspace @plantain/shared",
    "test": "npm run test --workspaces --if-present",
    "test:shared": "npm run test --workspace @plantain/shared",
    "dev:web": "npm run dev --workspace @plantain/web",
    "dev:api": "npm run dev --workspace @plantain/api",
    "docker:up": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/docker-up.ps1",
    "db:start": "npm run docker:up && npx supabase start",
    "db:stop": "npx supabase stop",
    "db:reset": "npx supabase db reset",
    "db:seed": "node scripts/seed-dictionary.mjs"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "supabase": "^2.20.5",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "pg": "^8.22.0"
  }
}
